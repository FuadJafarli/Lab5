<!DOCTYPE html>
<html>
<head>
<style>
  body { display: flex; justify-content: center; align-items: center; min-height: 100vh; background: #f0f2f5; }
  .card { width: 260px; background: #fff; border-radius: 12px; box-shadow: 0 4px 16px rgba(0,0,0,0.12); overflow: hidden; position: relative; }
  .badge { position: absolute; top: 12px; left: 12px; background: #e74c3c; color: #fff; padding: 4px 10px; border-radius: 20px; font-size: 12px; z-index: 10; }
  .img { height: 180px; background: #dce8f5; display: flex; justify-content: center; align-items: center; font-size: 60px; }
  .body { padding: 16px; display: flex; flex-direction: column; gap: 8px; }
  .name { font-size: 18px; font-weight: bold; color: #2c3e50; }
  .price { font-size: 22px; font-weight: bold; color: #e74c3c; }
  .price span { font-size: 13px; color: #aaa; text-decoration: line-through; margin-left: 6px; }
  .btn { padding: 12px; background: #3498db; color: #fff; border: none; border-radius: 8px; cursor: pointer; width: 100%; }
  .btn:hover { background: #2980b9; }
</style>
</head>
<body>
  <div class="card">
    <div class="badge">-20%</div>
    <div class="img">👟</div>
    <div class="body">
      <div class="name">Nike Air Max</div>
      <div class="price">₼159.99 <span>₼199.99</span></div>
      <button class="btn">Səbətə əlavə et</button>
    </div>
  </div>
</body>
</html>

